<?xml version="1.0" encoding="utf-8"?>
<!-- LoginActivity: Role selector (Customer / Admin) + Sign In -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MAESTRO AUTOWORKS"
            android:textColor="@color/yellow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="32dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign In to Your Account"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp"/>

        <!-- ROLE SELECTOR LABEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOGIN AS"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <!-- ROLE TABS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Customer Tab (active by default) -->
            <LinearLayout
                android:id="@+id/tabCustomer"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/yellow"
                android:layout_marginEnd="8dp"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128100;"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CUSTOMER"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Admin Tab -->
            <LinearLayout
                android:id="@+id/tabAdmin"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/black_card"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128295;"
                    android:textSize="20sp"/>

                <TextView
                    android:id="@+id/tvAdminTabLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADMIN"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Admin notice strip (visible only when Admin tab is selected) -->
        <LinearLayout
            android:id="@+id/layoutAdminNotice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/black_card"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#128274; "
                android:textSize="14sp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Admin access only. Use your administrator credentials. Unauthorized access attempts are logged."
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

        <!-- USERNAME -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Username" android:textColor="@color/muted" android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Enter your username"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="@color/muted"
            android:background="@color/black_card"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- PASSWORD -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Password" android:textColor="@color/muted" android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Enter your password"
            android:inputType="textPassword"
            android:textColor="@color/yellow"
            android:textColorHint="@color/muted"
            android:background="@color/black_card"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvPasswordInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password text color: YELLOW (secure mode)"
            android:textColor="@color/yellow"
            android:textSize="11sp"
            android:layout_marginBottom="24dp"/>

        <!-- SIGN IN BUTTON (label changes with role) -->
        <Button
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SIGN IN AS CUSTOMER"
            android:backgroundTint="@color/yellow"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- REGISTER LINK (hidden when Admin is selected) -->
        <TextView
            android:id="@+id/tvGoRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Don&#8217;t have an account? Sign Up"
            android:textColor="@color/yellow"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black_card"
            android:layout_marginBottom="16dp"/>

        <!-- VISIT WEBSITE -->
        <Button
            android:id="@+id/btnVisitWebsite"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="VISIT OUR WEBSITE"
            android:backgroundTint="@color/black_card"
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- BACK -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#8592; Back to Home"
            android:textColor="@color/muted"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
