<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_input.xml
    ─────────────────────────────────────────────────────────────────────────
    Rounded EditText background for all form fields across the app.
    Fill:   @color/black_input  (#2A2A2A)  — slightly lighter than the card
    Border: @color/border       (#282828)  — 1.5dp stroke, nearly invisible
             at rest; toggled to amber (#F5A623) via code when focused.
    Corner: 12dp radius — matches btn_primary.xml and field-input in the
            HTML mockup exactly.

    Usage (EditText / TextInputEditText):
        android:background="@drawable/bg_input"
    ─────────────────────────────────────────────────────────────────────────
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state: amber border to signal active field -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#2A2A2A" />
            <stroke android:width="1.5dp" android:color="#F5A623" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Error / activated state (used programmatically) -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="#2A2A2A" />
            <stroke android:width="1.5dp" android:color="#E05252" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Default / unfocused state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2A2A2A" />
            <stroke android:width="1.5dp" android:color="#282828" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>
