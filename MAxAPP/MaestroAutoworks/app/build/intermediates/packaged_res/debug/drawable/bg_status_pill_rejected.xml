<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_status_pill_rejected.xml
    ─────────────────────────────────────────────────────────────────────────
    Pill badge background for users with verification_status = "rejected".
    Fill:   #2A0A0A  — deep red tint (mirrors pending's amber tint logic)
    Border: #E05252  — @color/danger red stroke
    Corner: 100dp   — fully rounded pill, matches all other status pills
    ─────────────────────────────────────────────────────────────────────────
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#2A0A0A" />
    <stroke android:width="1dp" android:color="#E05252" />
    <corners android:radius="100dp" />
</shape>
