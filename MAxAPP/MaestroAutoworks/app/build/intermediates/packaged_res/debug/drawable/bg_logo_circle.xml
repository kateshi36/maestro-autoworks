<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_logo_circle.xml
    Used as the background on the hero logo ImageView in activity_login.xml.
    Solid black oval — clips the PNG's grey background so only the logo
    skull shows against the clean black circle.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid black fill -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#000000" />
        </shape>
    </item>
</layer-list>
