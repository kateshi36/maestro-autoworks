<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_appt_card.xml
    ─────────────────────────────────────────────────────────────────────────
    Card background for each appointment row in the RecyclerView.
    Fill:   #1A1A1A  (@color/black_card)  — one step above page black
    Border: #2E2E2E                        — slightly brighter than @border
                                             to give a faint card lift
    Corner: 14dp                           — rounded but not pill-shaped
    ─────────────────────────────────────────────────────────────────────────
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1A1A1A" />
    <stroke android:width="1dp" android:color="#2E2E2E" />
    <corners android:radius="14dp" />
</shape>
