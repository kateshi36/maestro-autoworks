<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_topbar_icon_btn.xml
    ─────────────────────────────────────────────────────────────────────────
    Semi-transparent black oval used as the background for the 36×36dp
    icon buttons that sit on top of the amber topbar (back arrow, hamburger,
    profile icon).

    The ~15% black overlay keeps the icon readable against the amber surface
    without fully opaquing it — matching the HTML mockup's rgba(0,0,0,0.15).

    Usage (ImageView / ImageButton inside TopBar):
        android:background="@drawable/bg_topbar_icon_btn"
        style="@style/TopBar.IconBtn"
    ─────────────────────────────────────────────────────────────────────────
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33000000">

    <!-- Ripple clipping mask -->
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="#26000000" />
        </shape>
    </item>

    <!-- Actual background -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#26000000" />  <!-- ~15% black -->
        </shape>
    </item>

</ripple>
