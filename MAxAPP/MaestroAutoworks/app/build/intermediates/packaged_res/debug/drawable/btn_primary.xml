<?xml version="1.0" encoding="utf-8"?>
<!--
    btn_primary.xml
    ─────────────────────────────────────────────────────────────────────────
    Primary amber button background used on every screen in the app.
    Wraps the shape in a ripple drawable so the press feedback is a
    system-standard ripple (dark overlay) rather than a flat color swap.

    Fill:    #F5A623  (@color/yellow)       — brand amber
    Pressed: #D4891A  (@color/yellow_dark)  — darker amber fallback for
             pre-Lollipop (not reached in practice; minSdk ≥ 21)
    Corner:  12dp — matches field-input radius in HTML mockup

    Usage (Button / TextView):
        android:background="@drawable/btn_primary"
        android:textColor="@color/black"
        android:textStyle="bold"
    ─────────────────────────────────────────────────────────────────────────
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#D4891A">

    <!-- Clipping mask — constrains ripple to the rounded rect -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#F5A623" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Actual background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F5A623" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</ripple>
