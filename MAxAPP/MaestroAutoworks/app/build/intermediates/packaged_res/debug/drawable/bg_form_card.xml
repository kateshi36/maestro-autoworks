<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_form_card.xml
    ─────────────────────────────────────────────────────────────────────────
    Card container wrapping the input fields on the Login screen.
    Fill:   #1C1C1C  (@color/surface2)
    Border: #282828  (@color/border) — 1.5dp, barely visible hairline
    Corner: 16dp — slightly larger than fields for visual layering
    ─────────────────────────────────────────────────────────────────────────
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1C1C1C" />
    <stroke android:width="1.5dp" android:color="#282828" />
    <corners android:radius="16dp" />
</shape>
