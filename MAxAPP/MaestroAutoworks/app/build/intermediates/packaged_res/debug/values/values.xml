<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#0A0A0A</color>
    <color name="black_card">#1A1A1A</color>
    <color name="black_ele">#222222</color>
    <color name="black_input">#2A2A2A</color>
    <color name="blue">#2196F3</color>
    <color name="colorAccent">#F5A623</color>
    <color name="colorPrimary">#F5A623</color>
    <color name="colorPrimaryDark">#D4891A</color>
    <color name="danger">#E05252</color>
    <color name="muted">#888888</color>
    <color name="purple">#7B61FF</color>
    <color name="success">#4CAF7D</color>
    <color name="white">#FFFFFF</color>
    <color name="yellow">#F5A623</color>
    <string name="app_name">Maestro Autoworks</string>
    <string name="shop_url">https://www.maestroautoworks.ph</string>
    <string name="tagline">Expert Auto Repair in Metro Manila</string>
    <style name="OtpBox">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/yellow</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@color/black_card</item>
        <item name="android:textColorHint">@color/muted</item>
    </style>
    <style name="Theme.MaestroAutoworks" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/yellow</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/yellow</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>
</resources>