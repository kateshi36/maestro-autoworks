<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider path declarations for Maestro Autoworks.

    Covers every directory that MediaPickerHelper may place a captured-image
    file on Android 9 and below (API ≤ 28).  On Android 10+ (API ≥ 29) the
    app uses MediaStore instead and these paths are never exercised, but
    declaring them here is harmless and keeps the manifest valid on all SDK
    levels.

    Path types used
    ═══════════════
    external-files-path  →  Context.getExternalFilesDir(...)
                            e.g. /sdcard/Android/data/<pkg>/files/Pictures/
                            App-private, removed on uninstall. No storage
                            permission required on any Android version.

    external-cache-path  →  Context.getExternalCacheDir()
                            e.g. /sdcard/Android/data/<pkg>/cache/
                            Used as a second write location if the Pictures
                            directory is unavailable.

    files-path           →  Context.getFilesDir()
                            Internal storage fallback when no external storage
                            is mounted at all.
-->
<paths>

    <!-- Primary: app-private Pictures folder on external storage             -->
    <!-- Matches getExternalFilesDir(Environment.DIRECTORY_PICTURES)          -->
    <external-files-path
        name="captured_images"
        path="Pictures/" />

    <!-- Secondary: app-private external cache (fallback if Pictures fails)   -->
    <external-cache-path
        name="captured_images_cache"
        path="." />

    <!-- Tertiary: internal files-dir (no-SD / emulator edge cases)           -->
    <files-path
        name="captured_images_internal"
        path="Pictures/" />

</paths>
