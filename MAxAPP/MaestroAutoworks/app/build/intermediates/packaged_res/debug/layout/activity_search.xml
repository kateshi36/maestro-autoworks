<?xml version="1.0" encoding="utf-8"?>
<!-- SearchActivity: AutoCompleteTextView -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="24dp">
        <!-- ═══ LOGO HEADER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@color/black">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/logo_maestro"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maestro Autoworks"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>



    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search Services"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Type to auto-suggest a service"
        android:textColor="@color/muted"
        android:textSize="13sp"
        android:layout_marginBottom="24dp"/>

    <!-- AutoCompleteTextView -->
    <AutoCompleteTextView
        android:id="@+id/autoComplete"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="e.g. Oil Change, Brake..."
        android:completionThreshold="1"
        android:textColor="@color/white"
        android:textColorHint="@color/muted"
        android:background="@color/black_card"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSearchGo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="SEARCH"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- Result display -->
    <TextView
        android:id="@+id/tvSearchResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/white"
        android:textSize="14sp"
        android:padding="16dp"
        android:background="@color/black_card"
        android:visibility="gone"/>

</LinearLayout>
