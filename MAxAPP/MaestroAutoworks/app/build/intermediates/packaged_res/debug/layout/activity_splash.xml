<?xml version="1.0" encoding="utf-8"?>
<!-- SplashActivity — all original IDs preserved, space evenly distributed -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yellow">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="40dp"
        android:paddingEnd="40dp">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/logo_maestro"
            android:scaleType="fitCenter"
            android:padding="20dp"
            android:background="@drawable/bg_splash_bolt_circle"
            android:visibility="invisible"
            android:layout_marginBottom="28dp"/>

        <TextView
            android:id="@+id/splashBrandName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAESTRO"
            android:textColor="@color/black"
            android:textSize="44sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:gravity="center"
            android:visibility="invisible"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your car deserves expert hands."
            android:textColor="#CC000000"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="invisible"/>

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingBottom="48dp">

        <View
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:background="@color/black"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EST. 2010 · QUEZON CITY"
            android:textColor="#CC000000"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnLetsStart"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Let's Start!"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/yellow"
            android:backgroundTint="@color/black"
            android:stateListAnimator="@null"
            android:visibility="visible"/>

    </LinearLayout>

</LinearLayout>
