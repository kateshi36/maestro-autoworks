<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_identity_verification.xml
    Step 10 — Post-Login Identity Verification (SMS OTP / Email OTP / Security Question)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── HEADER ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MAESTRO AUTOWORKS"
            android:textColor="@color/yellow"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="32dp"/>

        <!-- Shield icon -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#128274;"
            android:textSize="48sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <!-- Dynamic greeting set from code -->
        <TextView
            android:id="@+id/tvVerifyGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verify Your Identity"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <!-- Subtitle — changes with active panel -->
        <TextView
            android:id="@+id/tvVerifySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter the 6-digit code sent to:"
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <!-- Masked contact (phone or email) -->
        <TextView
            android:id="@+id/tvMaskedContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="your registered contact"
            android:textColor="@color/yellow"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- OTP hint (hidden in production) -->
        <TextView
            android:id="@+id/tvOtpHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/black_card"
            android:padding="10dp"
            android:text=""
            android:textColor="@color/success"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  OTP PANEL                                                     -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutOtpSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- ── CHANNEL SELECTOR TABS ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- SMS tab -->
                <LinearLayout
                    android:id="@+id/tabOtpSms"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@color/yellow"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#128241; SMS OTP"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Email tab -->
                <LinearLayout
                    android:id="@+id/tabOtpEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@color/black_card"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9993; Email OTP"
                        android:textColor="@color/muted"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 6 OTP input boxes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <EditText android:id="@+id/etOtp1" style="@style/OtpBox"/>
                <EditText android:id="@+id/etOtp2" style="@style/OtpBox"/>
                <EditText android:id="@+id/etOtp3" style="@style/OtpBox"/>
                <EditText android:id="@+id/etOtp4" style="@style/OtpBox"/>
                <EditText android:id="@+id/etOtp5" style="@style/OtpBox"/>
                <EditText android:id="@+id/etOtp6" style="@style/OtpBox"/>

            </LinearLayout>

            <!-- Timer -->
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Code expires in 1:00"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <!-- Attempts remaining -->
            <TextView
                android:id="@+id/tvAttempts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Attempts remaining: 3 / 3"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Verify button -->
            <Button
                android:id="@+id/btnVerifyOtp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="VERIFY CODE"
                android:backgroundTint="@color/yellow"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Resend button -->
            <Button
                android:id="@+id/btnResendOtp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="RESEND CODE"
                android:backgroundTint="@color/black_card"
                android:textColor="@color/muted"
                android:textStyle="bold"
                android:enabled="false"
                android:layout_marginBottom="12dp"/>

            <!-- Security question fallback link -->
            <TextView
                android:id="@+id/btnUseSecurityQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Can&#8217;t receive code? Answer a security question"
                android:textColor="@color/yellow"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="12dp"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  SECURITY QUESTION PANEL                                       -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutSecurityQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128100; SECURITY QUESTION"
                    android:textColor="@color/yellow"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvSecurityQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/etSecurityAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Your answer"
                    android:inputType="text"
                    android:textColor="@color/white"
                    android:textColorHint="@color/muted"
                    android:background="@color/black_ele"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnSubmitSecurityAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="SUBMIT ANSWER"
                    android:backgroundTint="@color/yellow"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  LOCKOUT PANEL                                                 -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutLockout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#128683;"
                android:textSize="48sp"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Too Many Failed Attempts"
                android:textColor="@color/danger"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="For your security, please answer your security question to unlock access."
                android:textColor="@color/muted"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnLockoutToSecurityQ"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ANSWER SECURITY QUESTION"
                android:backgroundTint="@color/yellow"
                android:textColor="@color/black"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ── DIVIDER ───────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black_card"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <!-- Security notice -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#128737; This step protects your account from unauthorized access. Never share your OTP."
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
