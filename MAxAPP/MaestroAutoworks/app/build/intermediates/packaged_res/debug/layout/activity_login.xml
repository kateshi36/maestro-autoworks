<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml  —  Sub-Stage 4B (polished)
    ═══════════════════════════════════════════════════════════════════════════
    Layout structure
    ────────────────
    1. Amber TOPBAR  — logo + brand centred (back btn hidden for root login)
    2. ScrollView → dark LinearLayout (#0A0A0A)
       a. HERO section   (bolt circle, brand name, tagline)
       b. "Sign In" heading + subtitle
       c. ROLE TABS      [Customer ▌ Admin]  selected=amber / unselected=#1A1A1A
       d. Admin notice strip  (GONE by default; shown when Admin tab active)
       e. FORM CARD      (#1C1C1C, 16dp corners)
              – EMAIL ADDRESS label + etUsername
              – PASSWORD label + etPassword + eye-toggle
              – Forgot Password link (right-aligned, amber)
       f. SIGN IN BUTTON  (amber, full-width, bold 15sp)
       g. Register link  (centred, muted + amber "Sign Up")

    IDs exposed to LoginActivity.java
    ──────────────────────────────────
    btnBack             topbar back (invisible on login root)
    tabCustomer         role-tab LinearLayout
    tabAdmin            role-tab LinearLayout
    tvCustomerLabel     customer tab label (tinted in code)
    tvAdminTabLabel     admin tab label
    layoutAdminNotice   notice strip
    etUsername          email/username EditText
    etPassword          password EditText
    btnTogglePassword   ImageView eye-toggle
    tvForgotPassword    forgot-password link
    btnSignIn           sign-in Button
    tvGoRegister        register link (GONE when Admin active)
    ═══════════════════════════════════════════════════════════════════════════
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <!-- ══════════════════════════════════════════════════════════
         1. FULL-WIDTH AMBER HERO HEADER  (matches mockup)
         ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/yellow"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Black circle containing the logo -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_black" />

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/logo_maestro"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAESTRO AUTOWORKS"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your car deserves expert hands."
            android:textColor="@color/black"
            android:textSize="13sp"
            android:alpha="0.7"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════
         2. SCROLLABLE BODY
         ══════════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="@color/black">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="36dp">

            <!-- ─────────────────────────────────────────────────
                 b. "Sign In" heading + subtitle
                 ───────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back! Choose your role to continue."
                android:textColor="@color/muted"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- ─────────────────────────────────────────────────
                 c. ROLE TABS
                 ───────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Customer Tab — SELECTED by default -->
                <LinearLayout
                    android:id="@+id/tabCustomer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_tab_selected"
                    android:layout_marginEnd="6dp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#128100;"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/tvCustomerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CUSTOMER"
                        android:textColor="@color/black"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Admin Tab — UNSELECTED by default -->
                <LinearLayout
                    android:id="@+id/tabAdmin"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_tab_unselected"
                    android:layout_marginStart="6dp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#128295;"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/tvAdminTabLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADMIN"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────────────────────────
                 d. ADMIN NOTICE STRIP  (GONE until Admin selected)
                 ───────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layoutAdminNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/black_card"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128274; "
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Admin access only. Use your administrator credentials. Unauthorized access attempts are logged."
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- ─────────────────────────────────────────────────
                 e. FORM CARD  (#1C1C1C)
                 ───────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_form_card"
                android:padding="20dp"
                android:layout_marginBottom="10dp">

                <!-- EMAIL ADDRESS label -->
                <TextView
                    style="@style/FieldLabel"
                    android:text="EMAIL ADDRESS OR USERNAME" />

                <!-- Email EditText -->
                <EditText
                    android:id="@+id/etUsername"
                    style="@style/FormField"
                    android:hint="Enter your email or username"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext" />

                <!-- PASSWORD label -->
                <TextView
                    style="@style/FieldLabel"
                    android:text="PASSWORD" />

                <!-- Password row: field + eye toggle -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <EditText
                        android:id="@+id/etPassword"
                        style="@style/FormField.Password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="0dp"
                        android:hint="Enter your password"
                        android:imeOptions="actionDone" />

                    <TextView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_alignParentEnd="true"
                        android:gravity="center"
                        android:text="&#128065;"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Toggle password visibility" />
                </RelativeLayout>

                <!-- Forgot password link — right-aligned, amber -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Forgot password?"
                    android:textColor="@color/yellow"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ─────────────────────────────────────────────────
                 f. SIGN IN BUTTON  (label toggled via code)
                 ───────────────────────────────────────────────── -->
            <Button
                android:id="@+id/btnSignIn"
                style="@style/BtnPrimary"
                android:text="SIGN IN AS CUSTOMER" />

            <!-- ─────────────────────────────────────────────────
                 g. REGISTER LINK  (GONE when Admin tab active)
                    Set text via Html.fromHtml in LoginActivity:
                    "Don't have an account? <font color=\"#F5A623\"><b>Sign Up</b></font>"
                 ───────────────────────────────────────────────── -->
            <TextView
                android:id="@+id/tvGoRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="12dp"
                android:text="Don\u2019t have an account? Sign Up"
                android:textColor="@color/muted"
                android:textSize="13sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>