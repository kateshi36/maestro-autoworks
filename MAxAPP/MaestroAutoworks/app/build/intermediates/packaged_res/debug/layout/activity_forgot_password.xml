<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ═══ LOGO HEADER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/logo_maestro"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maestro Autoworks"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Page Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forgot Password"
            android:textColor="@color/yellow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <!-- Step indicator -->
        <TextView
            android:id="@+id/tvFpStepIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:layout_marginBottom="28dp"/>

        <!-- ══════════════════════════════════════════
             STEP 1 — Find Your Account
             ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutFpStep1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#128274;  Find Your Account"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enter the email address or phone number linked to your account. We will send a one-time password (OTP) to verify your identity."
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address or Phone Number"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etFpEmailOrPhone"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="juan@email.com or 09XX-XXX-XXXX"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/white"
                    android:textColorHint="@color/muted"
                    android:background="@color/black"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnFpStep1Next"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SEND OTP VIA EMAIL"
                android:backgroundTint="@color/yellow"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvFpBackToLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&#8592; Back to Sign In"
                android:textColor="@color/muted"
                android:gravity="center"
                android:padding="12dp"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             STEP 2 — Enter OTP
             ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutFpStep2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#128231;  Check Your Email"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvFpOtpSentTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A 6-digit OTP was sent to your email."
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter OTP"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etFpOtp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="e.g. 483920"
                    android:inputType="number"
                    android:maxLength="6"
                    android:textColor="@color/yellow"
                    android:textColorHint="@color/muted"
                    android:background="@color/black"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- Countdown / Resend row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvFpCountdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OTP expires in 5:00"
                        android:textColor="@color/muted"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvFpResend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resend OTP"
                        android:textColor="@color/yellow"
                        android:textSize="12sp"
                        android:padding="4dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnFpVerifyOtp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="VERIFY OTP"
                android:backgroundTint="@color/yellow"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnFpStep2Back"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="&#8592; BACK"
                android:backgroundTint="@color/black_card"
                android:textColor="@color/muted"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             STEP 3 — Reset Password
             ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutFpStep3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/black_card"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&#128274;  Set New Password"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose a strong password you haven't used before."
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp"/>

                <!-- New Password with eye toggle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Password *"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp">

                    <EditText
                        android:id="@+id/etFpNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="At least 6 characters"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="@color/muted"
                        android:background="@color/black"
                        android:paddingStart="16dp"
                        android:paddingEnd="56dp"/>

                    <TextView
                        android:id="@+id/btnToggleNewPassword"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_alignParentEnd="true"
                        android:gravity="center"
                        android:text="&#128065;"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </RelativeLayout>

                <!-- Password strength bar -->
                <TextView
                    android:id="@+id/tvFpPasswordStrength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Strength: —"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Confirm Password with eye toggle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm New Password *"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp">

                    <EditText
                        android:id="@+id/etFpConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="Repeat new password"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="@color/muted"
                        android:background="@color/black"
                        android:paddingStart="16dp"
                        android:paddingEnd="56dp"/>

                    <TextView
                        android:id="@+id/btnToggleConfirmPassword"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_alignParentEnd="true"
                        android:gravity="center"
                        android:text="&#128065;"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </RelativeLayout>

                <!-- Match indicator -->
                <TextView
                    android:id="@+id/tvFpPasswordMatch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnFpResetPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="RESET PASSWORD"
                android:backgroundTint="@color/yellow"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnFpStep3Back"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="&#8592; BACK"
                android:backgroundTint="@color/black_card"
                android:textColor="@color/muted"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
