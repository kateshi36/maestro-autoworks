<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_appointments.xml  —  Stage 4B redesign
    ─────────────────────────────────────────────────────────────────────────
    Structure
      LinearLayout (root, vertical, @color/surface)
        ├─ LinearLayout  #topbar          amber, 60dp, back arrow + title
        └─ NestedScrollView               fills remainder
             └─ LinearLayout (vertical)
                  ├─ Section header       title "My Appointments" + subtitle
                  ├─ tvNotifBadge         in-app notification pill (Step 5)
                  ├─ Divider
                  ├─ "YOUR BOOKINGS" label
                  ├─ tvEmpty              hidden until list is empty
                  └─ RecyclerView         id=listAppointments

    IDs preserved from original:
      tvNotifBadge, tvEmpty, listAppointments
    ─────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- ═══ TOPBAR ═══ -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/yellow">

        <!-- Back button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="center"
            android:background="@drawable/bg_topbar_icon_btn"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Go back" />

        <!-- Flexible spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Screen title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY APPOINTMENTS"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.06" />

        <!-- Flexible spacer (mirrors back button width for optical centering) -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Right placeholder — keeps title centred -->
        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />

    </LinearLayout>
    <!-- end topbar -->

    <!-- ═══ SCROLLABLE BODY ═══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Section header ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Appointments"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track and manage your service bookings"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- ── In-App Notification Badge (Step 5) ── -->
            <!--
                Visibility toggled in AppointmentsActivity.java via refreshNotifBadge().
                Kept gone by default; shown when unread notifications exist.
            -->
            <TextView
                android:id="@+id/tvNotifBadge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_status_pill_confirmed"
                android:textColor="@color/success"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone" />

            <!-- ── Divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="0dp" />

            <!-- ── "YOUR BOOKINGS" section label ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="YOUR BOOKINGS"
                    android:textColor="@color/yellow"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14" />

            </LinearLayout>

            <!-- ── Empty state ── -->
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No appointments yet.\nBook your first service!"
                android:textColor="@color/muted"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.6"
                android:padding="40dp"
                android:visibility="gone" />

            <!-- ── RecyclerView (replaces ListView) ── -->
            <!--
                nestedScrollingEnabled="false" lets it expand to full height
                inside the NestedScrollView so all cards are always visible.
                LinearLayoutManager is set in AppointmentsActivity.java (4E).
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/listAppointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="24dp"
                android:clipToPadding="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
    <!-- end scrollable body -->

</LinearLayout>
