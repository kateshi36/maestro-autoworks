<?xml version="1.0" encoding="utf-8"?>
<!--
    list_item_appointment.xml  —  Stage 4C redesign
    ─────────────────────────────────────────────────────────────────────────
    Rich card row for each appointment in the RecyclerView.

    Card anatomy (horizontal):
      ┌──────────────────────────────────────────────────────┐
      │  [🛢️]   Oil Change & Filter          [● PENDING]    │
      │  icon    📅  May 10, 2026· 9:00 AM                  │
      │  circle  🚗  ABC 1234              ₱699.00           │
      └──────────────────────────────────────────────────────┘

    IDs
      tvApptIcon     — emoji icon (🛢️ oil / ⚙️ tune-up / 🔧 other)
                       set dynamically in AppointmentAdapter (Stage 4D)
      tvApptService  — service name    (was in original adapter)
      tvApptStatus   — status text + background swapped in adapter (4D)
                       uses bg_status_pill_pending / confirmed / cancelled
      tvApptDate     — "date  ·  time"  (was in original adapter)
      tvApptPlate    — plate number only (adapter now sets plate separately)
      tvApptPrice    — total price       (NEW — split from tvApptPlate)

    Elevation-style depth is achieved by the border in bg_appt_card
    combined with android:elevation="2dp" on the root card.
    ─────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_appt_card"
    android:elevation="2dp"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- ── Service Icon Circle ── -->
    <!--
        48×48 amber-tinted icon container. The emoji inside is swapped
        by the adapter based on serviceName:
          "Oil Change"   → 🛢️
          "Engine Tune"  → ⚙️
          anything else  → 🔧
    -->
    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_feature_icon"
        android:layout_marginEnd="14dp">

        <TextView
            android:id="@+id/tvApptIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧"
            android:textSize="22sp"
            android:gravity="center" />

    </LinearLayout>
    <!-- end icon circle -->

    <!-- ── Content Column ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- ── Row 1: Service name + Status pill ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="7dp">

            <TextView
                android:id="@+id/tvApptService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginEnd="8dp" />

            <!--
                Status pill — background drawable swapped in adapter:
                  pending   → @drawable/bg_status_pill_pending   (amber border)
                  confirmed → @drawable/bg_status_pill_confirmed  (green border)
                  cancelled → @drawable/bg_status_pill_cancelled  (red border)
                Text colour is also swapped to match the border colour.
            -->
            <TextView
                android:id="@+id/tvApptStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_status_pill_pending"
                android:textColor="@color/yellow" />

        </LinearLayout>
        <!-- end Row 1 -->

        <!-- ── Row 2: Date & Time ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp">

            <!-- Calendar emoji label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="11sp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/tvApptDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="12sp" />

        </LinearLayout>
        <!-- end Row 2 -->

        <!-- ── Row 3: Plate + Price ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Car emoji label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗"
                android:textSize="11sp"
                android:layout_marginEnd="5dp" />

            <!-- Plate number — weight=1 so price stays right-aligned -->
            <TextView
                android:id="@+id/tvApptPlate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Total price — only visible when totalPrice > 0 (set in adapter) -->
            <TextView
                android:id="@+id/tvApptPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/yellow"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
        <!-- end Row 3 -->

    </LinearLayout>
    <!-- end content column -->

</LinearLayout>
