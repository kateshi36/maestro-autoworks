<?xml version="1.0" encoding="utf-8"?>
<!-- ServicesActivity: ListView & ArrayAdapter -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">
        <!-- ═══ LOGO HEADER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@color/black">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/logo_maestro"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maestro Autoworks"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>



    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Our Services"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap a service to book it"
        android:textColor="@color/muted"
        android:textSize="13sp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp"/>

    <!-- ListView populated by ArrayAdapter -->
    <ListView
        android:id="@+id/listServices"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@color/black_card"
        android:dividerHeight="1dp"/>

</LinearLayout>
