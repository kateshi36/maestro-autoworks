<?xml version="1.0" encoding="utf-8"?>
<!-- BookActivity: Spinner & ArrayAdapter, RadioButton & BG Color, CheckBox & Text Color, RatingBar & AlertDialog -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <!-- ═══ LOGO HEADER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@color/black">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/logo_maestro"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maestro Autoworks"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>



        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book an Appointment"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <!-- Step indicator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VEHICLE DETAILS"
            android:textColor="@color/yellow"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- ── SPINNER: Car Model ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CAR MODEL" android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerCarModel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/black_card"
            android:popupBackground="@color/black_card"
            android:layout_marginBottom="24dp"/>

        <!-- ── SPINNER: Year Model ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="YEAR MODEL" android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerYearModel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/black_card"
            android:popupBackground="@color/black_card"
            android:layout_marginBottom="24dp"/>

        <!-- ── RADIO BUTTONS: Fuel Type ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FUEL TYPE"
            android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/layoutFuelType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/black_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <RadioGroup android:id="@+id/rgFuelType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton android:id="@+id/rbGasoline"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="⛽  Gasoline"
                    android:textColor="@color/white" android:buttonTint="@color/yellow"/>

                <RadioButton android:id="@+id/rbDiesel"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="🛢️  Diesel"
                    android:textColor="@color/white" android:buttonTint="@color/yellow"/>
            </RadioGroup>
        </LinearLayout>

        <!-- ═══ VEHICLE INSPECTION CHECKLIST ═══ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="VEHICLE INSPECTION CHECKLIST"
            android:textColor="@color/yellow"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Select all concerns that apply to your vehicle:"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/black_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <CheckBox android:id="@+id/cbConcernEngine"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🔧  Engine — knocking, misfires, or rough idle"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbConcernBrakes"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🛑  Brakes — squealing, grinding, or soft pedal"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbConcernAircon"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="❄️  Air-Con — not cooling or unusual odour"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbConcernElectrical"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="⚡  Electrical — battery, lights, or dashboard warnings"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbConcernTires"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🛞  Tires / Wheels — vibration, pulling, or uneven wear"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbConcernOil"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🛢️  Oil / Fluids — leaks or low fluid levels"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbConcernSteering"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🔄  Steering / Suspension — stiffness or clunking"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbConcernExhaust"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="💨  Exhaust — smoke colour changes or loud noise"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>
        </LinearLayout>

        <!-- Optional notes field -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ADDITIONAL NOTES (optional)"
            android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etAdditionalNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="96dp"
            android:hint="Describe any other issues or details about your vehicle…"
            android:inputType="textMultiLine|textCapSentences"
            android:gravity="top|start"
            android:textColor="@color/white"
            android:textColorHint="@color/muted"
            android:background="@color/black_card"
            android:padding="14dp"
            android:layout_marginBottom="16dp"/>

        <!-- Live concern summary card (hidden until user selects at least one item) -->
        <LinearLayout
            android:id="@+id/layoutConcernSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/black_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📋  INSPECTION SUMMARY"
                android:textColor="@color/yellow"
                android:textSize="10sp" android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvConcernSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.6"/>
        </LinearLayout>

        <!-- Divider between vehicle details and service booking -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/black_card" android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVICE DETAILS"
            android:textColor="@color/yellow"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- ── SPINNER: Choose Service ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SELECT SERVICE" android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/black_card"
            android:popupBackground="@color/black_card"
            android:layout_marginBottom="24dp"/>

        <!-- ── EDITTEXT: Car Plate -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CAR PLATE NUMBER" android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etCarPlate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="e.g. ABC 1234"
            android:inputType="textCapCharacters"
            android:textColor="@color/white"
            android:textColorHint="@color/muted"
            android:background="@color/black_card"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvCarPlateError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E05252"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"/>

        <!-- ── CALENDAR: Preferred Date ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PREFERRED DATE" android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <!-- Date picker row: shows chosen date + calendar button -->
        <LinearLayout
            android:id="@+id/layoutSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/black_card"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#128197;"
                android:textSize="20sp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap to choose a date"
                android:textColor="@color/muted"
                android:textSize="14sp"/>

            <Button
                android:id="@+id/btnPickDate"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="SELECT"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:backgroundTint="@color/yellow"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>\n
        </LinearLayout>

        <!-- Hidden EditText keeps the date string for the existing save logic -->
        <EditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <!-- ── RADIO BUTTONS: Time Slot & Background Color changes -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PREFERRED TIME (changes background color)"
            android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/layoutTimeSlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/black_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <RadioGroup android:id="@+id/rgTimeSlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton android:id="@+id/rbMorning"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="🌅  Morning  (8:00 AM – 12:00 PM)"
                    android:textColor="@color/white" android:buttonTint="@color/yellow"/>

                <RadioButton android:id="@+id/rbAfternoon"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="☀️  Afternoon  (1:00 PM – 5:00 PM)"
                    android:textColor="@color/white" android:buttonTint="@color/yellow"/>

                <RadioButton android:id="@+id/rbEarlyBird"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="🌄  Early Bird  (8:00 AM – 9:00 AM)"
                    android:textColor="@color/white" android:buttonTint="@color/yellow"/>
            </RadioGroup>
        </LinearLayout>

        <!-- ── CHECKBOX: Add-ons & Text Color changes -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ADD-ONS (checking changes text color)"
            android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@color/black_card"
            android:padding="16dp" android:layout_marginBottom="24dp">

            <CheckBox android:id="@+id/cbOilCheck"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Free Oil Level Check (+₱0)"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbCarWash"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Exterior Car Wash (+₱150)"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>

            <CheckBox android:id="@+id/cbInspection"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="27-Point Safety Inspection (+₱250)"
                android:textColor="@color/muted" android:buttonTint="@color/yellow"/>
        </LinearLayout>

        <!-- Total computation display -->
        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estimated Total:  ₱0.00"
            android:textColor="@color/yellow"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginBottom="24dp"/>

        <!-- ── RATINGBAR: Rate your last experience -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="RATE YOUR LAST VISIT"
            android:textColor="@color/yellow"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="0"
            android:stepSize="1"
            android:progressTint="@color/yellow"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvRatingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap a star to rate"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:layout_marginBottom="32dp"/>

        <!-- Submit — triggers AlertDialog -->
        <Button
            android:id="@+id/btnBookNow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CONFIRM BOOKING"
            android:backgroundTint="@color/yellow"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
