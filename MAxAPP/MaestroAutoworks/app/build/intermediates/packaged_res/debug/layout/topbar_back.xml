<?xml version="1.0" encoding="utf-8"?>
<!--
    topbar_back.xml
    ─────────────────────────────────────────────────────────────────────────
    Reusable amber topbar for secondary screens (Register, ForgotPassword,
    IdentityVerification, Book, Services, Appointments, About, etc.).

    Structure:
        [← back button]   [title — weight=1, centered]   [36dp spacer]

    The trailing 36dp spacer mirrors the back button so the title text is
    optically centred across the full bar width. Replace the spacer with a
    real icon button (e.g. a help/info icon) when needed on a specific screen
    by setting android:visibility="visible" and assigning an id.

    IDs exposed to Activities:
        @id/btnBack       — ImageView; call finish() in onClick
        @id/tvTopbarTitle — TextView; set screen-specific title

    Include with:
        <include layout="@layout/topbar_back"
                 android:layout_width="match_parent"
                 android:layout_height="56dp" />

    Or apply style="@style/TopBar" on a LinearLayout and replicate the
    children inline if you need to override individual attributes.
    ─────────────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/TopBar">

    <!-- ── Back button ── -->
    <ImageView
        android:id="@+id/btnBack"
        style="@style/TopBar.IconBtn"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Go back"
        android:clickable="true"
        android:focusable="true" />

    <!-- ── Screen title (centred between the two 36dp flanking views) ── -->
    <TextView
        android:id="@+id/tvTopbarTitle"
        style="@style/TopBar.Title"
        android:text="" />

    <!-- ── Trailing spacer — keeps title optically centred ── -->
    <!--   Replace visibility with "visible" + assign an id when you need
           a right-side action icon on a specific screen.              -->
    <View
        android:id="@+id/viewTopbarTrail"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:visibility="invisible" />

</LinearLayout>
