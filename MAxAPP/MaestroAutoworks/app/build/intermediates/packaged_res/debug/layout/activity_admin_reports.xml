<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <Button android:id="@+id/btnReportsBack"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="← Back" android:textColor="@color/muted"
                android:background="@color/black_card" android:textSize="12sp"
                android:layout_marginEnd="12dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ADMIN · REPORTS"
                    android:textColor="@color/yellow" android:textSize="10sp"
                    android:letterSpacing="0.15" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Reporting Dashboard"
                    android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Status Summary Tiles (2x3 grid using nested LinearLayouts) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="BOOKING SUMMARY" android:textColor="@color/yellow"
            android:textSize="10sp" android:letterSpacing="0.15" android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">

            <LinearLayout android:id="@+id/rptTotal"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/black_card" android:padding="10dp"
                android:layout_marginEnd="6dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/yellow"
                    android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="All" android:textColor="@color/muted" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/rptPending"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/black_card" android:padding="10dp"
                android:layout_marginEnd="6dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/yellow"
                    android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pending" android:textColor="@color/muted" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/rptConfirmed"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/black_card" android:padding="10dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/yellow"
                    android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Confirmed" android:textColor="@color/muted" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="20dp">

            <LinearLayout android:id="@+id/rptCompleted"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/black_card" android:padding="10dp"
                android:layout_marginEnd="6dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/success"
                    android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Completed" android:textColor="@color/muted" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/rptDeclined"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/black_card" android:padding="10dp"
                android:layout_marginEnd="6dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/danger"
                    android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Declined" android:textColor="@color/muted" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/rptCancelled"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@color/black_card" android:padding="10dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/muted"
                    android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cancelled" android:textColor="@color/muted" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Completion Rate -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@color/black_card"
            android:padding="14dp" android:layout_marginBottom="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="COMPLETION RATE"
                android:textColor="@color/yellow" android:textSize="10sp"
                android:letterSpacing="0.15" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tvCompletionRate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0% Completion Rate"
                android:textColor="@color/white" android:textSize="14sp" android:layout_marginBottom="10dp"/>
            <LinearLayout android:id="@+id/completionBarBg"
                android:layout_width="match_parent" android:layout_height="12dp"
                android:background="@color/black_input">
                <LinearLayout android:id="@+id/completionBarFill"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:background="@color/success"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Top Services -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TOP SERVICES BY BOOKINGS"
            android:textColor="@color/yellow" android:textSize="10sp"
            android:letterSpacing="0.15" android:textStyle="bold" android:layout_marginBottom="12dp"/>
        <LinearLayout android:id="@+id/topServicesContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@color/black_card"
            android:padding="14dp" android:layout_marginBottom="20dp"/>

        <!-- Daily Activity -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="BOOKING ACTIVITY (RECENT)"
            android:textColor="@color/yellow" android:textSize="10sp"
            android:letterSpacing="0.15" android:textStyle="bold" android:layout_marginBottom="12dp"/>
        <LinearLayout android:id="@+id/dailyActivityContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@color/black_card"
            android:padding="14dp" android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
