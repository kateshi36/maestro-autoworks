<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.maestro.autoworks"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- WRITE_EXTERNAL_STORAGE only needed on Android 9 and below -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <permission
        android:name="com.maestro.autoworks.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.maestro.autoworks.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.MaestroAutoworks" >

        <!-- 1. Splash / Landing -->
        <activity
            android:name="com.maestro.autoworks.activities.MainActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 2. Login -->
        <activity
            android:name="com.maestro.autoworks.activities.LoginActivity"
            android:exported="false" />

        <!-- 3. Register -->
        <activity
            android:name="com.maestro.autoworks.activities.RegisterActivity"
            android:exported="false" />

        <!-- 4. Customer Home -->
        <activity
            android:name="com.maestro.autoworks.activities.HomeActivity"
            android:exported="false" />

        <!-- 5. Services -->
        <activity
            android:name="com.maestro.autoworks.activities.ServicesActivity"
            android:exported="false" />

        <!-- 6. Book Appointment -->
        <activity
            android:name="com.maestro.autoworks.activities.BookActivity"
            android:exported="false" />

        <!-- 7. My Appointments -->
        <activity
            android:name="com.maestro.autoworks.activities.AppointmentsActivity"
            android:exported="false" />

        <!-- 8. About -->
        <activity
            android:name="com.maestro.autoworks.activities.AboutActivity"
            android:exported="false" />

        <!-- 9. WebView -->
        <activity
            android:name="com.maestro.autoworks.activities.WebViewActivity"
            android:exported="false" />

        <!-- 10. Identity Verification (OTP / 2FA — Step 10) -->
        <activity
            android:name="com.maestro.autoworks.activities.IdentityVerificationActivity"
            android:exported="false" />

        <!-- 11. Search -->
        <activity
            android:name="com.maestro.autoworks.activities.SearchActivity"
            android:exported="false" />

        <!-- ADMIN SECTION -->
        <!-- A1. Admin Dashboard -->
        <activity
            android:name="com.maestro.autoworks.activities.AdminDashboardActivity"
            android:exported="false" />

        <!-- A2. Admin Appointments -->
        <activity
            android:name="com.maestro.autoworks.activities.AdminReportsActivity"
            android:exported="false"
            android:label="Reports — Maestro Autoworks" />
        <activity
            android:name="com.maestro.autoworks.activities.AdminPmsActivity"
            android:exported="false"
            android:label="Repair Tracker — Maestro Autoworks" />
        <activity
            android:name="com.maestro.autoworks.activities.AdminAppointmentsActivity"
            android:exported="false" />

        <!-- A3. Admin Services -->
        <activity
            android:name="com.maestro.autoworks.activities.AdminServicesActivity"
            android:exported="false" />

        <!-- FileProvider for OR/CR camera capture on Android 9 and below -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.maestro.autoworks.provider"
            android:exported="false"
            android:grantUriPermissions="true" >
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.maestro.autoworks.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>