<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_amber_tag.xml
    ─────────────────────────────────────────────────────────────────────────
    Badge / pill background for the Hero "Amber Tag" eyebrow label.
    Filled with the brand amber (#F5A623) and fully rounded on all four
    corners (cornerRadius = half the expected view height ≈ 20dp → 100dp
    is large enough to guarantee a perfect pill at any measured height).
    ─────────────────────────────────────────────────────────────────────────
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Amber fill — matches @color/yellow (#F5A623) -->
    <solid android:color="#F5A623" />

    <!-- Pill corners -->
    <corners android:radius="100dp" />

</shape>
