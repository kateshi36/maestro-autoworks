<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_status_pill_confirmed.xml
    ─────────────────────────────────────────────────────────────────────────
    Pill badge background for appointments with status = "confirmed".
    Fill:   #0D2318  — deep green tint
    Border: #4CAF7D  — @color/success green stroke
    Corner: 100dp   — fully rounded pill shape
    ─────────────────────────────────────────────────────────────────────────
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0D2318" />
    <stroke android:width="1dp" android:color="#4CAF7D" />
    <corners android:radius="100dp" />
</shape>
