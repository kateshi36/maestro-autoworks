<?xml version="1.0" encoding="utf-8"?>
<!--
    btn_ghost.xml
    ─────────────────────────────────────────────────────────────────────────
    Ghost / outline button background. Transparent fill, visible border,
    white text (set on the widget, not here).

    Border:  1.5dp #333333 at rest  →  #444444 on press (via ripple)
    Fill:    transparent at rest  →  #1AFFFFFF (10% white) on press
    Corner:  12dp — same as btn_primary for visual consistency

    Usage (Button / TextView):
        android:background="@drawable/btn_ghost"
        android:textColor="@color/white"
    ─────────────────────────────────────────────────────────────────────────
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#1AFFFFFF">

    <!-- Clipping mask — keeps ripple within rounded rect -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Actual ghost background -->
    <item>
        <selector>
            <!-- Pressed: subtle white fill + brighter border -->
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <solid android:color="#1AFFFFFF" />
                    <stroke android:width="1.5dp" android:color="#444444" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <!-- Default: transparent + dim border -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                    <stroke android:width="1.5dp" android:color="#333333" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </selector>
    </item>

</ripple>
