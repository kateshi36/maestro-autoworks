<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_status_pill_pending.xml
    ─────────────────────────────────────────────────────────────────────────
    Pill badge background for appointments with status = "pending".
    Fill:   #2A1F00  — dark amber tint (keeps the pill readable on dark cards)
    Border: #F5A623  — brand yellow (@color/yellow) stroke for the amber tone
    Corner: 100dp   — fully rounded pill shape
    ─────────────────────────────────────────────────────────────────────────
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#2A1F00" />
    <stroke android:width="1dp" android:color="#F5A623" />
    <corners android:radius="100dp" />
</shape>
