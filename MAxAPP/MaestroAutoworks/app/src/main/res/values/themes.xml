<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- OTP single-digit input box used in IdentityVerificationActivity -->
    <style name="OtpBox">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/yellow</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@color/black_card</item>
        <item name="android:textColorHint">@color/muted</item>
    </style>

    <!-- Splash screen theme — no action bar, full black background -->
    <style name="Theme.MaestroAutoworks.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/yellow</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/yellow</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
    </style>

    <style name="Theme.MaestroAutoworks" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/yellow</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/yellow</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>
</resources>
