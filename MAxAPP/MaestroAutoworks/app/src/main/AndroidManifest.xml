<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MaestroAutoworks">

        <!-- 1. Splash / Landing -->
        <activity android:name=".activities.MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- 2. Login -->
        <activity android:name=".activities.LoginActivity" android:exported="false"/>

        <!-- 3. Register -->
        <activity android:name=".activities.RegisterActivity" android:exported="false"/>

        <!-- 4. Customer Home -->
        <activity android:name=".activities.HomeActivity" android:exported="false"/>

        <!-- 5. Services -->
        <activity android:name=".activities.ServicesActivity" android:exported="false"/>

        <!-- 6. Book Appointment -->
        <activity android:name=".activities.BookActivity" android:exported="false"/>

        <!-- 7. My Appointments -->
        <activity android:name=".activities.AppointmentsActivity" android:exported="false"/>

        <!-- 8. About -->
        <activity android:name=".activities.AboutActivity" android:exported="false"/>

        <!-- 9. WebView -->
        <activity android:name=".activities.WebViewActivity" android:exported="false"/>

        <!-- 10. Search -->
        <activity android:name=".activities.SearchActivity" android:exported="false"/>

        <!-- ADMIN SECTION -->
        <!-- A1. Admin Dashboard -->
        <activity android:name=".activities.AdminDashboardActivity" android:exported="false"/>

        <!-- A2. Admin Appointments -->
        <activity android:name=".activities.AdminReportsActivity"
            android:label="Reports — Maestro Autoworks"
            android:exported="false"/>
        <activity android:name=".activities.AdminPmsActivity"
            android:label="Repair Tracker — Maestro Autoworks"
            android:exported="false"/>
        <activity android:name=".activities.AdminAppointmentsActivity" android:exported="false"/>

        <!-- A3. Admin Services -->
        <activity android:name=".activities.AdminServicesActivity" android:exported="false"/>

    </application>
</manifest>
