<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MaestroAutoworks">

        <!-- 1. Splash / Landing -->
        <activity android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- 2. Login — EditText PasswordType & TextColor -->
        <activity android:name=".activities.LoginActivity" android:exported="false"/>

        <!-- 3. Register — EditText, TextView, Button, Toast, Computation & Validation -->
        <activity android:name=".activities.RegisterActivity" android:exported="false"/>

        <!-- 4. Home Dashboard — Intent navigation hub -->
        <activity android:name=".activities.HomeActivity" android:exported="false"/>

        <!-- 5. Services — ListView & ArrayAdapter -->
        <activity android:name=".activities.ServicesActivity" android:exported="false"/>

        <!-- 6. Book Appointment — Spinner, RadioButton, CheckBox, RatingBar, AlertDialog -->
        <activity android:name=".activities.BookActivity" android:exported="false"/>

        <!-- 7. My Appointments — SQLite ListView -->
        <activity android:name=".activities.AppointmentsActivity" android:exported="false"/>

        <!-- 8. About / Appearance — RadioButton BG color, CheckBox text color -->
        <activity android:name=".activities.AboutActivity" android:exported="false"/>

        <!-- 9. Contact / WebView -->
        <activity android:name=".activities.WebViewActivity" android:exported="false"/>

        <!-- 10. Search Services — AutoCompleteTextView -->
        <activity android:name=".activities.SearchActivity" android:exported="false"/>

    </application>
</manifest>
