<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:id="@+id/tvDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Notes to Customer (optional)"
        android:textSize="12sp" android:textColor="#666666" android:layout_marginBottom="4dp"/>

    <EditText android:id="@+id/etAdminNote"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:hint="e.g. Slot confirmed. Please arrive 10 min early."
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:background="#F0F0F0"
        android:padding="8dp"/>
</LinearLayout>
