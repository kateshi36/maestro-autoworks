<?xml version="1.0" encoding="utf-8"?>
<!-- WebViewActivity: Embedded browser for the Maestro Autoworks website -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@color/black_card">

        <Button
            android:id="@+id/btnWebBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="&#8592; Back"
            android:textSize="12sp"
            android:backgroundTint="@color/black"
            android:textColor="@color/yellow"/>

        <TextView
            android:id="@+id/tvWebTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Maestro Autoworks Website"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"/>

        <Button
            android:id="@+id/btnWebRefresh"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="&#8635;"
            android:backgroundTint="@color/black"
            android:textColor="@color/yellow"/>
    </LinearLayout>

    <!-- Loading progress bar -->
    <ProgressBar
        android:id="@+id/webProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="@color/yellow"
        android:progressBackgroundTint="@color/black_card"
        android:visibility="gone"/>

    <!-- Web content -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>
