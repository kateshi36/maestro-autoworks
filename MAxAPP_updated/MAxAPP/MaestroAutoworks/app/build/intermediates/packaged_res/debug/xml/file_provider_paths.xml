<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider paths for OR/CR camera capture (Android 9 and below).
    On Android 10+, MediaStore is used instead and this file is not needed,
    but declaring it here is harmless.
-->
<paths>
    <!-- Matches getExternalFilesDir(Environment.DIRECTORY_PICTURES) -->
    <external-files-path
        name="orcr_images"
        path="Pictures/" />
</paths>
